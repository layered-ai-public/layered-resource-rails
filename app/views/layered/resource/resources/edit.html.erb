<div class="l-ui-container--spread">
  <div>
    <%= l_ui_breadcrumbs do %>
      <%= l_ui_breadcrumb_item "Home", root_path %>
      <% layered_breadcrumbs.each do |crumb| %>
        <%= l_ui_breadcrumb_item crumb[:label], crumb[:path] %>
      <% end %>
      <%= l_ui_breadcrumb_item @model.model_name.human.pluralize, layered_routes.send(:"layered_#{@layered_route_key}_path") %>
    <% end %>

    <h1 class="l-ui-heading">Edit <%= @model.model_name.human.downcase %></h1>
  </div>
</div>

<div class="l-ui-utility--mt-sm">
  <%= l_ui_form(@record, fields: @fields, url: @form_url, method: :patch) %>
</div>
