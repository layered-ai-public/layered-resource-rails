<% content_for :l_ui_body_class, "l-ui-body--always-show-navigation" %>

<% unless devise_controller? %>
  <% content_for :l_ui_navigation_items do %>
    <%= l_ui_navigation_item "Home", root_path %>
    <%= l_ui_navigation_item "Examples", examples_path do %>
      <%= l_ui_navigation_item "Posts", layered_posts_path %>
      <%= l_ui_navigation_item "Users", layered_users_path do %>
        <%= l_ui_navigation_item "Read Only", layered_readonly_users_path %>
        <%= l_ui_navigation_item "Deletable", layered_deletable_users_path %>
      <% end %>
      <%= l_ui_navigation_item "Admin Posts", layered_admin_posts_path %>
    <% end %>
  <% end %>
<% end %>

<%= render template: "layouts/layered_ui/application" %>
