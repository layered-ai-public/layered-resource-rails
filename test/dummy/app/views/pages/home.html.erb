<%= l_ui_breadcrumbs do %>
  <%= l_ui_breadcrumb_item "#{gem_spec.name} (v#{gem_spec.version.to_s})" %>
<% end %>
<h1>Home</h1>

<p class="l-ui-utility--mt-md">
  <%= gem_spec.description %>
</p>

<h2 class="l-ui-utility--mt-xl">Examples</h2>
<ul class="l-ui-list l-ui-utility--mt-md">
  <li><%= link_to "Posts", layered_posts_path %> - standalone, all posts</li>
  <li><%= link_to "Users", layered_users_path %> - index with posts count linking to nested posts</li>
</ul>

<h2 class="l-ui-utility--mt-xl">Requirements</h2>
<ul class="l-ui-list l-ui-utility--mt-md">
  <li>Ruby on Rails >= 8.0</li>
  <li><a href="https://github.com/layered-ai-public/layered-ui-rails">layered-ui-rails</a> ~> 0.8</li>
  <li><a href="https://github.com/activerecord-hackery/ransack">Ransack</a> ~> 4.0</li>
  <li><a href="https://github.com/ddnexus/pagy">Pagy</a> ~> 43.2</li>
</ul>

<h2 class="l-ui-utility--mt-xl">Installation</h2>
<p class="l-ui-utility--mt-md">Add to your Gemfile:</p>
<pre class="l-ui-surface l-ui-utility--mt-md"><code>gem "layered-resource-rails"</code></pre>
<p class="l-ui-utility--mt-lg">Then run:</p>
<pre class="l-ui-surface l-ui-utility--mt-md"><code>bundle install</code></pre>

<h2 class="l-ui-utility--mt-xl">Setup</h2>

<h3 class="l-ui-utility--mt-lg">1. Routes</h3>
<p class="l-ui-utility--mt-md">Use <code>layered_resources</code> in your routes to register a model for CRUD management:</p>
<pre class="l-ui-surface l-ui-utility--mt-md"><code># config/routes.rb
layered_resources :posts</code></pre>
<p class="l-ui-utility--mt-md">Restrict actions with the <code>only:</code> option:</p>
<pre class="l-ui-surface l-ui-utility--mt-md"><code>layered_resources :posts, only: [:index]            # read-only
layered_resources :posts, only: %i[index destroy]    # list + delete</code></pre>

<h3 class="l-ui-utility--mt-lg">2. Resource definition</h3>
<p class="l-ui-utility--mt-md">Create a resource class in <code>app/layered_resources/</code> that inherits from <code>Layered::Resource::Base</code>:</p>
<pre class="l-ui-surface l-ui-utility--mt-md"><code>class PostResource < Layered::Resource::Base
  model Post

  columns [
    { attribute: :title, primary: true },
    { attribute: :created_at, label: "Created" }
  ]

  # Fields with a presence validation on the model are automatically marked as required.
  fields [
    { attribute: :title },
    { attribute: :body, as: :text }
  ]

  search_fields [:title, :body]
end</code></pre>

<h3 class="l-ui-utility--mt-lg">3. Resource configuration</h3>
<p class="l-ui-utility--mt-md">Override these class methods on your resource to customise behaviour:</p>
<% config_methods = [
  { method: "columns", purpose: "Columns displayed on the index table" },
  { method: "fields", purpose: "Form fields for new/edit (empty = read-only, no CRUD forms)" },
  { method: "search_fields", purpose: "Ransack search attributes" },
  { method: "default_sort", purpose: "Default sort order for the index" },
  { method: "permitted_params", purpose: "Strong params (derived from fields by default)" },
  { method: "scope(controller)", purpose: "Base scope (override for tenant isolation)" },
  { method: "build_record(controller)", purpose: "How to instantiate new records" },
  { method: "after_save_path(controller, record)", purpose: "Redirect target after create/update/destroy" }
] %>

<div class="l-ui-utility--mt-md">
  <%= l_ui_table(config_methods,
        columns: [
          { attribute: :method, label: "Method", render: ->(r) { tag.code(r[:method]) } },
          { attribute: :purpose, label: "Purpose", render: ->(r) { r[:purpose] } }
        ],
        caption: "Resource configuration methods") %>
</div>

<h2 class="l-ui-utility--mt-xl">Authentication</h2>
<p class="l-ui-utility--mt-md">Protect layered resources with a before_action by setting:</p>
<pre class="l-ui-surface l-ui-utility--mt-md"><code># config/initializers/layered_resource.rb
Layered::Resource.before_action = :authenticate_user!</code></pre>

